rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['id', 'email']) &&
               data.id == request.auth.uid &&
               data.email is string && data.email.size() <= 100 &&
               (data.get('age', '') is string) &&
               (data.get('gender', '') is string) &&
               (data.get('height', '') is string) &&
               (data.get('weight', '') is string);
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().id == userId;
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly([
          'age', 'gender', 'height', 'weight', 'bloodType', 
          'allergies', 'conditions', 'smoking', 'caretakerName', 
          'caretakerPhone', 'onboarding_complete', 'updatedAt', 'name'
        ])
      );
    }

    // 2. Records Collection
    match /records/{recordId} {
      function isValidRecord(data) {
        return data.keys().hasAll(['userId', 'timestamp', 'sys', 'dia', 'pulse']) &&
               data.userId == request.auth.uid &&
               data.sys is int && data.sys >= 0 && data.sys <= 300 &&
               data.dia is int && data.dia >= 0 && data.dia <= 200 &&
               data.pulse is int && data.pulse >= 0 && data.pulse <= 300 &&
               (data.get('notes', '') is string) && (data.get('notes', '').size() <= 1000);
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidRecord(incoming()) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidRecord(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['sys', 'dia', 'pulse', 'status', 'notes', 'timestamp'])
      );
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    // 3. Alerts Collection
    match /alerts/{alertId} {
      function isValidAlert(data) {
        return data.keys().hasAll(['userId', 'type', 'title', 'timestamp', 'isRead']) &&
               data.userId == request.auth.uid &&
               data.type in ['Emergency', 'Warning', 'Info'] &&
               data.title is string && data.title.size() <= 200;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidAlert(incoming()) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && isOwner(existing().userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['isRead'])
      );
    }
  }
}
