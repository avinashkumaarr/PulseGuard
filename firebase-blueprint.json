{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Private profile data for a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "age": { "type": "string" },
        "gender": { "type": "string" },
        "height": { "type": "string" },
        "weight": { "type": "string" },
        "bloodType": { "type": "string" },
        "allergies": { "type": "string" },
        "conditions": { "type": "string" },
        "smoking": { "type": "string" },
        "caretakerName": { "type": "string" },
        "caretakerPhone": { "type": "string" },
        "onboarding_complete": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email"]
    },
    "HealthRecord": {
      "title": "Health Record",
      "description": "Blood pressure and pulse reading record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "sys": { "type": "integer" },
        "dia": { "type": "integer" },
        "pulse": { "type": "integer" },
        "status": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "timestamp", "sys", "dia", "pulse"]
    },
    "Alert": {
      "title": "Alert",
      "description": "Health alert or notification.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["Emergency", "Warning", "Info"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isRead": { "type": "boolean" }
      },
      "required": ["userId", "type", "title", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile with private biological data."
    },
    "/records/{recordId}": {
      "schema": "HealthRecord",
      "description": "Blood pressure readings."
    },
    "/alerts/{alertId}": {
      "schema": "Alert",
      "description": "Health alerts and system notifications."
    }
  }
}
